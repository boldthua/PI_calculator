<Window
    x:Class="PiCalculator.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PiCalculator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="0"
            Background="#F0F0F0"
            BorderBrush="Gray"
            BorderThickness="0,0,0,1">
            <TextBlock
                Margin="5"
                HorizontalAlignment="Center"
                FontSize="18"
                FontWeight="Black"
                Text="PI Calculator" />
        </Border>

        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Label
                VerticalAlignment="Center"
                Content="Sample Size"
                FontSize="18" />
            <TextBox
                Grid.Column="1"
                Margin="5"
                VerticalContentAlignment="Center"
                FontSize="16"
                Text="{Binding sample}" />
            <Button
                Grid.Column="2"
                Margin="5"
                Padding="20,5"
                Command="{Binding command}"
                CommandParameter="{Binding}"
                Content="Add"
                FontSize="16"
                IsEnabled="{Binding IsToStop}" />
            <Button
                Grid.Column="3"
                Margin="5"
                Padding="20,5"
                Command="{Binding stopCommand}"
                CommandParameter="{Binding}"
                Content="{Binding StopOrNot}"
                FontSize="16" />

        </Grid>



        <DataGrid
            Grid.Row="2"
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            GridLinesVisibility="All"
            HeadersVisibility="Column"
            HorizontalGridLinesBrush="LightGray"
            ItemsSource="{Binding missions}"
            VerticalGridLinesBrush="LightGray">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#D9E5F3" />
                    <Setter Property="Foreground" Value="Black" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="Padding" Value="10,5" />
                    <Setter Property="FontSize" Value="16" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="BorderBrush" Value="Gray" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Sample}"
                    Header="Sample" />
                <DataGridTextColumn
                    Width="*"
                    Binding="{Binding Time}"
                    Header="Time" />
                <DataGridTemplateColumn Width="*" Header="Value">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Grid Margin="5,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid Margin="5,0">
                                    <TextBlock
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Text="{Binding Value}"
                                        Visibility="{Binding IsCompleted, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                    <ProgressBar
                                        Width="120"
                                        Height="15"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsToCancel, Converter={StaticResource BooleanToVisibilityConverter}}"
                                        Value="{Binding Progress}" />
                                </Grid>

                                <Button
                                    Grid.Column="2"
                                    Padding="5,2"
                                    Command="{Binding cancelCommand}"
                                    Content="取消"
                                    Cursor="Hand"
                                    FontSize="12"
                                    Visibility="{Binding IsToCancel, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</Window>